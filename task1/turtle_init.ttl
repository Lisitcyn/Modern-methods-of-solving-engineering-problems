@prefix : <http://www.example.edu/university#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Онтология
: a owl:Ontology .

#################################################################
#    Классы (3 и более)
#################################################################

:Студент a owl:Class ;
    rdfs:label "Студент"@ru ;
    rdfs:comment "Человек, обучающийся в университете."@ru .

:Преподаватель a owl:Class ;
    rdfs:label "Преподаватель"@ru ;
    rdfs:comment "Человек, преподающий в университете."@ru .

:Университет a owl:Class ;
    rdfs:label "Университет"@ru ;
    rdfs:comment "Высшее учебное заведение."@ru .

:Кафедра a owl:Class ;
    rdfs:label "Кафедра"@ru ;
    rdfs:comment "Структурное подразделение университета."@ru .

#################################################################
#    Объектные свойства (2 и более)
#################################################################

# Свойство "учится в" (связывает Студента и Университет)
:учитсяВ a owl:ObjectProperty ;
    rdfs:domain :Студент ;
    rdfs:range :Университет ;
    rdfs:label "учится в"@ru ;
    rdfs:comment "Указывает университет, в котором учится студент."@ru .

# Свойство "работает на" (связывает Преподавателя и Кафедру)
:работаетНа a owl:ObjectProperty ;
    rdfs:domain :Преподаватель ;
    rdfs:range :Кафедра ;
    rdfs:label "работает на"@ru ;
    rdfs:comment "Указывает кафедру, на которой работает преподаватель."@ru .

# Свойство "преподает у" (связывает Преподавателя и Студента)
:преподаетУ a owl:ObjectProperty ;
    rdfs:domain :Преподаватель ;
    rdfs:range :Студент ;
    rdfs:label "преподает у"@ru ;
    rdfs:comment "Указывает студентов, у которых преподает данный преподаватель."@ru .

#################################################################
#    Экземпляры (Индивиды) (5 и более)
#################################################################

# Экземпляры Университета
:МГУ a :Университет ;
    rdfs:label "Московский государственный университет"@ru .

:СПбГУ a :Университет ;
    rdfs:label "Санкт-Петербургский государственный университет"@ru .

# Экземпляры Кафедры
:КафедраИнформатики a :Кафедра ;
    rdfs:label "Кафедра информатики"@ru .

:КафедраФизики a :Кафедра ;
    rdfs:label "Кафедра физики"@ru .

# Экземпляры Студентов
:Иван a :Студент ;
    rdfs:label "Иван Петров"@ru ;
    :учитсяВ :МГУ .

:Мария a :Студент ;
    rdfs:label "Мария Иванова"@ru ;
    :учитсяВ :МГУ .

:Петр a :Студент ;
    rdfs:label "Петр Сидоров"@ru ;
    :учитсяВ :СПбГУ .

# Экземпляры Преподавателей
:Алексей a :Преподаватель ;
    rdfs:label "Алексей Смирнов"@ru ;
    :работаетНа :КафедраИнформатики ;
    :преподаетУ :Иван, :Мария .

:Елена a :Преподаватель ;
    rdfs:label "Елена Кузнецова"@ru ;
    :работаетНа :КафедраФизики ;
    :преподаетУ :Петр .