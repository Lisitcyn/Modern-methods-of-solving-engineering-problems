# Проверка 1: Найти все стабилизаторы, работающие на высоте >3000м
PREFIX : <http://example.org/stabilizer#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?стабилизатор ?высота
WHERE {
  ?стабилизатор a :Стабилизатор .
  ?стабилизатор :работаетВУсловиях ?условия .
  ?условия a :ВысотныеУсловия .
  ?условия :высотаНадУровнемМоря ?высота .
  FILTER (?высота > 3000)
}

# Проверка 2: Проверить ограничение мощности для высотных условий
PREFIX : <http://example.org/stabilizer#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?стабилизатор ?максМощность ?высота
WHERE {
  ?стабилизатор a :Стабилизатор .
  ?стабилизатор :работаетВУсловиях ?условия .
  ?условия a :ВысотныеУсловия .
  ?условия :высотаНадУровнемМоря ?высота .
  ?стабилизатор :максимальнаяМощность ?максМощность .
  FILTER (?высота > 3000 && ?максМощность > 1700)
}

# Проверка 3: Найти все стабилизаторы, требующие дополнительных устройств
PREFIX : <http://example.org/stabilizer#>

SELECT ?стабилизатор ?устройство
WHERE {
  ?стабилизатор :требуетДопУстройство ?устройство .
}