@prefix : <http://www.example.org/family#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Онтология
: a owl:Ontology .

#################################################################
#    Классы
#################################################################

:Человек a owl:Class ;
    rdfs:label "Человек"@ru ;
    rdfs:comment "Класс, представляющий человека в родословной."@ru .

#################################################################
#    Объектные свойства
#################################################################

# Основное свойство "имеет родителя" (не транзитивное, прямое)
:имеетРодителя a owl:ObjectProperty ;
    rdfs:domain :Человек ;
    rdfs:range :Человек ;
    rdfs:label "имеет родителя"@ru ;
    rdfs:comment "Непосредственное отношение ребенок-родитель."@ru ;
    owl:propertyChainAxiom ( :имеетРодителя ) .  # Базовое свойство

# Транзитивное свойство "имеет предка" (для определения всех предков)
:имеетПредка a owl:ObjectProperty ;
    rdfs:domain :Человек ;
    rdfs:range :Человек ;
    rdfs:label "имеет предка"@ru ;
    rdfs:comment "Транзитивное отношение, связывающее человека со всеми его предками."@ru ;
    a owl:TransitiveProperty ;
    owl:propertyChainAxiom ( :имеетРодителя :имеетПредка ) .

# Обратное свойство "имеет потомка" (для определения всех потомков)
:имеетПотомка a owl:ObjectProperty ;
    rdfs:domain :Человек ;
    rdfs:range :Человек ;
    rdfs:label "имеет потомка"@ru ;
    rdfs:comment "Транзитивное отношение, связывающее человека со всеми его потомками."@ru ;
    a owl:TransitiveProperty ;
    owl:inverseOf :имеетПредка .

# Свойство для обеспечения уникальности родителей (опционально)
:имеетОтца a owl:ObjectProperty ;
    rdfs:subPropertyOf :имеетРодителя ;
    rdfs:domain :Человек ;
    rdfs:range :Человек ;
    rdfs:label "имеет отца"@ru .

:имеетМать a owl:ObjectProperty ;
    rdfs:subPropertyOf :имеетРодителя ;
    rdfs:domain :Человек ;
    rdfs:range :Человек ;
    rdfs:label "имеет мать"@ru .

#################################################################
#    Экземпляры (5+ человек с родственными связями)
#################################################################

# Создаем 7 человек для демонстрации транзитивности
:Иван a :Человек ;
    rdfs:label "Иван"@ru ;
    :имеетРодителя :Петр, :Мария .  # Иван - сын Петра и Марии

:Петр a :Человек ;
    rdfs:label "Петр"@ru ;
    :имеетРодителя :Николай, :Анна .  # Петр - сын Николая и Анны

:Мария a :Человек ;
    rdfs:label "Мария"@ru .

:Николай a :Человек ;
    rdfs:label "Николай"@ru .

:Анна a :Человек ;
    rdfs:label "Анна"@ru .

:Елена a :Человек ;
    rdfs:label "Елена"@ru ;
    :имеетРодителя :Иван .  # Елена - дочь Ивана

:Сергей a :Человек ;
    rdfs:label "Сергей"@ru ;
    :имеетРодителя :Елена .  # Сергей - сын Елены

#################################################################
#    Аксиомы для вывода транзитивных связей
#################################################################

[ a owl:Axiom ;
  rdfs:comment "Если A имеет родителя B, и B имеет предка C, то A имеет предка C"@ru ;
  owl:annotatedProperty owl:propertyChainAxiom ;
  owl:annotatedSource :имеетПредка ;
  owl:annotatedTarget ( :имеетРодителя :имеетПредка )
] .

[ a owl:Axiom ;
  rdfs:comment "Свойство 'имеет предка' транзитивно: если A имеет предка B и B имеет предка C, то A имеет предка C"@ru ;
  owl:annotatedProperty rdf:type ;
  owl:annotatedSource :имеетПредка ;
  owl:annotatedTarget owl:TransitiveProperty
] .